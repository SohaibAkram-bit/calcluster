---
import ToolLayout from '../Layouts/ToolLayout.astro';
---

<ToolLayout
  title="Contact CalCluster"
  description="Get in touch with CalCluster for questions, suggestions, or feedback."
  canonicalUrl="https://calcluster.com/contact"
>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-slate-900 mb-6">Contact Us</h1>
    
    <p class="text-slate-600 leading-relaxed mb-8">
      We'd love to hear from you. For questions, suggestions, or feedback reach out directly.
    </p>

    <div class="mb-8">
      <a href="mailto:iamraisohaib@gmail.com" class="text-2xl md:text-3xl font-semibold text-[#1D9E75] hover:text-[#168561] hover:underline transition-colors">
        iamraisohaib@gmail.com
      </a>
    </div>

    <p class="text-slate-500">
      We typically respond within 1-2 business days.
    </p>
  </div>
</ToolLayout>