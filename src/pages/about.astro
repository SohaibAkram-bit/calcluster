---
import ToolLayout from '../Layouts/ToolLayout.astro';
---

<ToolLayout
  title="About CalCluster — Free Online Calculators"
  description="Learn about CalCluster, a free collection of online calculators for math, science, health, and more."
  canonicalUrl="https://calcluster.com/about/"
>
  <div class="max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-slate-900 mb-6">About CalCluster</h1>
    
    <p class="text-slate-600 leading-relaxed mb-8">
      CalCluster is a free collection of online calculators built for students, professionals, and curious minds. Fast, accurate, and ad-supported to keep everything free.
    </p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10 mb-4">What We Offer</h2>
    <p class="text-slate-600 leading-relaxed mb-8">
      We provide a diverse range of calculators and converters across multiple categories, including Math, Science, Health, Fun, and Utility. Whether you're solving complex equations or just satisfying your curiosity, we have a tool for you.
    </p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10 mb-4">Our Mission</h2>
    <p class="text-slate-600 leading-relaxed mb-8">
      Our mission is simple: to keep our tools free, accurate, and accessible to everyone on the web.
    </p>

    <h2 class="text-xl font-semibold text-slate-900 mt-10 mb-4">Contact</h2>
    <p class="text-slate-600 leading-relaxed mb-8">
      For questions or suggestions, please email us at 
      <a href="mailto:iamraisohaib@gmail.com" class="text-[#1D9E75] hover:underline">iamraisohaib@gmail.com</a>.
    </p>
  </div>
</ToolLayout>