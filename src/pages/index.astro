---
import ToolLayout from '../Layouts/ToolLayout.astro';

const tools = [
  {
    name: "Scale Calculator",
    description: "Easily convert measurements for scale models and drawings.",
    link: "/tools/scale-calculator"
  },
  {
    name: "Percent Decrease",
    description: "Calculate the percentage decrease between two numbers.",
    link: "/tools/percent-decrease"
  },
  {
    name: "Absolute Value",
    description: "Find the absolute value of any real number instantly.",
    link: "/tools/absolute-value"
  },
  {
    name: "Moon Phase Compatibility",
    description: "Check your relationship compatibility based on moon phases.",
    link: "/tools/moon-phase-compatibility"
  },
  {
    name: "RPE Calculator",
    description: "Calculate your Rate of Perceived Exertion for lifting.",
    link: "/tools/rpe-calculator"
  },
  {
    name: "Download Time",
    description: "Estimate exactly how long a file will take to download.",
    link: "/tools/download-time"
  }
];
---

<ToolLayout
  title="CalCluster — Free Online Calculators"
  description="Free online calculators for math, science, health, and more."
  canonicalUrl="https://calcluster.iamraisohaib.workers.dev"
>
  <!-- Hero Section -->
  <section class="py-16 md:py-24 flex flex-col items-center text-center">
    <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-4">
      Free Online Calculators
    </h1>
    <p class="text-lg md:text-xl text-slate-600 max-w-2xl mb-8">
      Fast, accurate tools for math, science, health, and more.
    </p>
    <a href="/categories" class="bg-[#1D9E75] hover:bg-[#168561] text-white font-medium text-lg px-8 py-3 rounded-lg transition-colors shadow-sm">
      Explore Tools
    </a>
  </section>

  <!-- Featured Tools Section -->
  <section class="py-12 border-t border-slate-200">
    <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-8 text-center md:text-left">Popular Tools</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map((tool) => (
        <div class="bg-white border border-slate-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow flex flex-col">
          <h3 class="text-xl font-semibold text-slate-900 mb-2">{tool.name}</h3>
          <p class="text-slate-600 mb-6 flex-grow">{tool.description}</p>
          <a href={tool.link} class="text-[#1D9E75] hover:text-[#168561] font-medium inline-flex items-center group">
            Open Tool
            <span class="ml-1 group-hover:translate-x-1 transition-transform">&rarr;</span>
          </a>
        </div>
      ))}
    </div>
  </section>
</ToolLayout>