---
import ToolLayout from '../../../Layouts/ToolLayout.astro';
import ScaleCalculatorContent from '../../../components/content/ScaleCalculatorContent.astro';
---
<ToolLayout
  title="Scale Calculator — Convert Any Scale Instantly (Free) | CalCluster"
  description="Scale calculator — convert real measurements to scale size, scale to real, or find the ratio instantly. Free tool for architecture, models, maps, and engineering."
  canonicalUrl="https://calcluster.com/tools/scale-calculator/"
  relatedTools={[
    { name: "Percent Decrease Calculator", link: "/tools/percent-decrease/" },
    { name: "Percent Increase Calculator", link: "/tools/percent-increase/" }
  ]}
>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does a scale ratio like 1:50 mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It means one unit on the drawing or model represents fifty of those same units in reality. One centimeter on a 1:50 floor plan equals 50 centimeters — half a meter — on site. The notation is dimensionless, so it works identically in millimeters, centimeters, or inches, provided the same unit is used on both sides. The ratio makes no assumption about which measurement system you are working in — only that the units match."
      }
    },
    {
      "@type": "Question",
      "name": "How do I convert real size to scale size?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Divide the real measurement by the ratio number. A 300cm wall at 1:100 scale becomes 300 ÷ 100 = 3cm on the drawing. The step most people skip is unit alignment — both the real size and the output need to be in the same unit before dividing. If the real measurement is in meters and the output is needed in centimeters, convert first. The scale calculator handles this automatically when input and output units differ."
      }
    },
    {
      "@type": "Question",
      "name": "How do I convert scale size back to real size?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Multiply the drawing or model measurement by the ratio number. A 5cm measurement on a 1:20 drawing equals 5 × 20 = 100cm in reality. This is simply the inverse of scaling down — you are reversing the original division. The same unit alignment rule applies: ensure both the scale size and the output unit are consistent before multiplying, or select matching units in the calculator."
      }
    },
    {
      "@type": "Question",
      "name": "What scales are typically used for architectural drawings?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 1:50 and 1:100 scales handle the majority of day-to-day architectural work — interior layouts at 1:50, full building floor plans at 1:100. Site plans typically use 1:500 or 1:1000 depending on how much surrounding context is required. Construction details such as joinery, fixings, and structural connections use 1:10 or 1:20 to show the assembly clearly at a workable drawing size."
      }
    },
    {
      "@type": "Question",
      "name": "What scale is used for model trains?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "HO scale at 1:87 is the global standard and the most widely produced scale worldwide. In the UK, OO gauge at 1:76 is the dominant choice for model railway layouts. N scale at 1:160 suits hobbyists with limited layout space, while O scale at 1:48 is popular for larger, more detailed models. The scale factor calculator presets include all four, so no manual ratio entry is needed."
      }
    },
    {
      "@type": "Question",
      "name": "Can this scale calculator work with any unit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The calculator accepts millimeters, centimeters, meters, inches, and feet, and converts between units automatically when input and output selections differ. A real measurement entered in feet can produce a scale result in millimeters with no manual conversion required. The scale ratio itself is dimensionless — it applies equally to any unit system as long as both sides of the calculation are consistent."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between scale up and scale down?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Scaling down reduces a large real-world dimension into a smaller drawing or model representation — the standard direction in architecture, cartography, and hobby modeling. A 1:50 scale produces something one-fiftieth the real size. Scaling up enlarges a small real measurement for a drawing, which occurs in engineering when small components need to be readable on paper — a 2:1 drawing shows the component at twice its actual size. Both directions use the same drawing scale calculator, just with the ratio applied in opposite directions."
      }
    },
    {
      "@type": "Question",
      "name": "What is the most common scale for military models?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "1:35 is the dominant scale for military ground vehicles — tanks, half-tracks, armored cars, and self-propelled artillery. Tamiya built much of its reputation on 1:35 armor kits, and Revell, Dragon, and Trumpeter have followed suit across their armor ranges. For military aircraft, 1:72 is the most widely available scale globally, with 1:48 popular for larger, more detailed builds when shelf space is not a constraint."
      }
    },
    {
      "@type": "Question",
      "name": "How does scaling work for area and volume?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Linear dimensions scale by the ratio itself. Area scales by the square of that ratio, and volume by the cube. A model at 1:10 scale is one-tenth the length of the original — but one-hundredth the surface area and one-thousandth the volume. This distinction matters in engineering analysis, fluid dynamics, heat transfer calculations, and structural modeling. The scale calculator returns the linear result — squaring or cubing the scale factor for area or volume must be done separately."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between scale factor and scale ratio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "They describe the same relationship in different notations. A scale ratio is written as 1:50 — two numbers separated by a colon. A scale factor expresses the same relationship as a single decimal: for 1:50, the scale factor is 0.02. In drawing and modeling contexts, ratio notation is standard. In mathematics and software, the decimal form is more common. Either way, the meaning is identical — one unit on the model equals fifty units in the real object."
      }
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to Use the Scale Calculator",
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "Select a conversion mode",
      "text": "Choose Real to Scale, Scale to Real, or Find Ratio depending on which values you have and what you need to calculate."
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "Enter the known measurement",
      "text": "Type your measurement into the input field and select the correct unit — millimeters, centimeters, meters, inches, or feet."
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "Enter or select the scale ratio",
      "text": "Type the ratio number manually or pick from the preset list. Common presets include 1:50, 1:100, 1:35, 1:87, and others."
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "Select your output unit",
      "text": "Choose the unit you want the result displayed in. The calculator converts between metric and imperial automatically."
    },
    {
      "@type": "HowToStep",
      "position": 5,
      "name": "Click Calculate",
      "text": "Press the Calculate button. The result appears instantly below the form."
    }
  ]
}
</script>

  <!-- Row 1: H1 & Intro -->
  <div class="mb-8">
    <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Scale Calculator</h1>
    <p class="text-slate-600 leading-relaxed text-lg max-w-3xl">
      The scale calculator converts real-world measurements to scaled drawing or model dimensions — and back again — across any scale ratio and any unit combination. Architects verifying floor plans at 1:100, engineers reading technical drawings at 1:50, model builders scaling scratch-built parts to fit a 1:35 kit, and students calculating map distances at 1:25,000 all rely on the same underlying math. The difficulty is rarely the formula itself — it is unit mismatches, direction errors, and the small mistakes that compound when switching between metric and imperial mid-project.
    </p>
  </div>

  <!-- Row 2: Two Columns (Calculator + Sidebar Ad) -->
  <div class="flex flex-col lg:flex-row gap-8 mb-8">
    
    <!-- Left Column: Calculator Widget (60% on desktop) -->
    <div class="w-full lg:w-[60%]">
      <div class="bg-white border border-slate-200 rounded-xl shadow-sm p-4 sm:p-6">
        
        <!-- Mode Selector -->
        <div class="flex flex-wrap gap-2 mb-6 border-b border-slate-100 pb-4">
          <button data-mode="1" class="mode-btn flex-1 bg-[#1D9E75] text-white font-medium py-2 px-3 rounded-lg text-sm sm:text-base transition-colors">Real &rarr; Scale</button>
          <button data-mode="2" class="mode-btn flex-1 bg-white border border-slate-200 text-slate-600 font-medium py-2 px-3 rounded-lg text-sm sm:text-base hover:bg-slate-50 transition-colors">Scale &rarr; Real</button>
          <button data-mode="3" class="mode-btn flex-1 bg-white border border-slate-200 text-slate-600 font-medium py-2 px-3 rounded-lg text-sm sm:text-base hover:bg-slate-50 transition-colors">Find Ratio</button>
        </div>

        <!-- Forms Container -->
        <div class="mb-6">
          
          <!-- Mode 1: Real to Scale -->
          <div id="mode-1-form" class="mode-form space-y-4 block">
            <div>
              <label for="m1-real" class="block text-sm font-semibold text-slate-700 mb-1">Real Size</label>
              <div class="flex gap-2">
                <input type="number" id="m1-real" step="any" min="0" placeholder="e.g. 500" class="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-900 bg-white" />
                <select id="m1-unit" class="w-24 px-2 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none bg-white text-slate-700">
                  <option value="mm">mm</option>
                  <option value="cm" selected>cm</option>
                  <option value="m">m</option>
                  <option value="in">in</option>
                  <option value="ft">ft</option>
                </select>
              </div>
            </div>
            <div>
              <label for="m1-ratio" class="block text-sm font-semibold text-slate-700 mb-1">Scale Ratio (1:X)</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-500 font-medium">1:</span>
                <input type="number" id="m1-ratio" step="any" min="0" placeholder="e.g. 50" class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-900 bg-white" />
              </div>
              <label for="m1-preset" class="block text-xs text-slate-500 mt-2 mb-1">Quick presets</label>
              <select id="m1-preset" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-700 bg-white text-sm">
                <option value="">-- Select Preset --</option>
                <option value="24">1:24 (Car models)</option>
                <option value="35">1:35 (Military models)</option>
                <option value="48">1:48 (Military aircraft)</option>
                <option value="50">1:50 (Architecture)</option>
                <option value="72">1:72 (Aircraft models)</option>
                <option value="76">1:76 (Railway OO)</option>
                <option value="87">1:87 (Railway HO)</option>
                <option value="100">1:100 (Architecture)</option>
                <option value="144">1:144 (Small aircraft)</option>
                <option value="200">1:200 (Ship models)</option>
              </select>
            </div>
            <div>
              <label for="m1-out-unit" class="block text-sm font-semibold text-slate-700 mb-1">Output Unit</label>
              <select id="m1-out-unit" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-700 bg-white">
                <option value="mm">mm</option>
                <option value="cm" selected>cm</option>
                <option value="m">m</option>
                <option value="in">in</option>
                <option value="ft">ft</option>
              </select>
            </div>
          </div>

          <!-- Mode 2: Scale to Real -->
          <div id="mode-2-form" class="mode-form space-y-4 hidden">
            <div>
              <label for="m2-scale" class="block text-sm font-semibold text-slate-700 mb-1">Scale Size</label>
              <div class="flex gap-2">
                <input type="number" id="m2-scale" step="any" min="0" placeholder="e.g. 10" class="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-900 bg-white" />
                <select id="m2-unit" class="w-24 px-2 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none bg-white text-slate-700">
                  <option value="mm">mm</option>
                  <option value="cm" selected>cm</option>
                  <option value="m">m</option>
                  <option value="in">in</option>
                  <option value="ft">ft</option>
                </select>
              </div>
            </div>
            <div>
              <label for="m2-ratio" class="block text-sm font-semibold text-slate-700 mb-1">Scale Ratio (1:X)</label>
              <div class="relative">
                <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-500 font-medium">1:</span>
                <input type="number" id="m2-ratio" step="any" min="0" placeholder="e.g. 50" class="w-full pl-9 pr-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-900 bg-white" />
              </div>
              <label for="m2-preset" class="block text-xs text-slate-500 mt-2 mb-1">Quick presets</label>
              <select id="m2-preset" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-700 bg-white text-sm">
                <option value="">-- Select Preset --</option>
                <option value="24">1:24 (Car models)</option>
                <option value="35">1:35 (Military models)</option>
                <option value="48">1:48 (Military aircraft)</option>
                <option value="50">1:50 (Architecture)</option>
                <option value="72">1:72 (Aircraft models)</option>
                <option value="76">1:76 (Railway OO)</option>
                <option value="87">1:87 (Railway HO)</option>
                <option value="100">1:100 (Architecture)</option>
                <option value="144">1:144 (Small aircraft)</option>
                <option value="200">1:200 (Ship models)</option>
              </select>
            </div>
            <div>
              <label for="m2-out-unit" class="block text-sm font-semibold text-slate-700 mb-1">Output Unit</label>
              <select id="m2-out-unit" class="w-full px-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-700 bg-white">
                <option value="mm">mm</option>
                <option value="cm" selected>cm</option>
                <option value="m">m</option>
                <option value="in">in</option>
                <option value="ft">ft</option>
              </select>
            </div>
          </div>

          <!-- Mode 3: Find Ratio -->
          <div id="mode-3-form" class="mode-form space-y-4 hidden">
            <div>
              <label for="m3-real" class="block text-sm font-semibold text-slate-700 mb-1">Real Size</label>
              <div class="flex gap-2">
                <input type="number" id="m3-real" step="any" min="0" placeholder="e.g. 500" class="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-900 bg-white" />
                <select id="m3-real-unit" class="w-24 px-2 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none bg-white text-slate-700">
                  <option value="mm">mm</option>
                  <option value="cm" selected>cm</option>
                  <option value="m">m</option>
                  <option value="in">in</option>
                  <option value="ft">ft</option>
                </select>
              </div>
            </div>
            <div>
              <label for="m3-scale" class="block text-sm font-semibold text-slate-700 mb-1">Scale Size</label>
              <div class="flex gap-2">
                <input type="number" id="m3-scale" step="any" min="0" placeholder="e.g. 10" class="flex-1 px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none text-slate-900 bg-white" />
                <select id="m3-scale-unit" class="w-24 px-2 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-[#1D9E75] focus:border-[#1D9E75] outline-none bg-white text-slate-700">
                  <option value="mm">mm</option>
                  <option value="cm" selected>cm</option>
                  <option value="m">m</option>
                  <option value="in">in</option>
                  <option value="ft">ft</option>
                </select>
              </div>
            </div>
          </div>

        </div>

        <!-- Error Message -->
        <div id="error-msg" class="text-red-500 text-sm font-medium mb-4 hidden"></div>

        <!-- Action Buttons -->
        <button id="calculate-btn" type="button" class="w-full bg-[#1D9E75] hover:bg-[#168561] text-white font-semibold py-3 px-4 rounded-lg transition-colors shadow-sm">
          Calculate
        </button>

        <!-- Result Display -->
        <div id="result-container" class="mt-6 text-center hidden p-4 bg-slate-50 rounded-lg border border-slate-100">
          <p class="text-sm text-slate-500 font-medium mb-1">Result</p>
          <div id="result-text" class="text-3xl md:text-4xl font-bold text-[#1D9E75] tracking-tight mb-3"></div>
          <button id="reset-btn" class="text-sm text-slate-400 hover:text-slate-600 underline transition-colors">Reset</button>
        </div>

      </div>
    </div>

    <!-- Right Column: Sidebar Ad (40% on desktop) -->
    <div class="w-full lg:w-[40%] flex justify-center lg:justify-end items-start">
      <div class="w-full max-w-[300px] h-[250px] bg-slate-100 border border-slate-200 rounded flex items-center justify-center text-slate-400 text-sm">
        Advertisement
      </div>
    </div>

  </div>

  <!-- Row 3: In-content Ad -->
  <div class="w-full max-w-[728px] mx-auto h-[90px] bg-slate-100 border border-slate-200 rounded flex items-center justify-center text-slate-400 text-sm my-12">
    Advertisement
  </div>

  <!-- Content Sections -->
  <ScaleCalculatorContent />

  <!-- Row 8: Bottom Ad -->
  <div class="w-full max-w-[728px] mx-auto h-[90px] bg-slate-100 border border-slate-200 rounded flex items-center justify-center text-slate-400 text-sm mt-12 mb-4">
    Advertisement
  </div>

  <!-- JS Logic -->
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      let currentMode = 1;
      
      const modeBtns = document.querySelectorAll('.mode-btn');
      const modeForms = document.querySelectorAll('.mode-form');
      const errorMsg = document.getElementById('error-msg');
      const resultContainer = document.getElementById('result-container');
      const resultText = document.getElementById('result-text');
      const calcBtn = document.getElementById('calculate-btn');
      const resetBtn = document.getElementById('reset-btn');

      const toMeters = { mm: 0.001, cm: 0.01, m: 1, in: 0.0254, ft: 0.3048 };

      const syncPreset = (ratioId, presetId) => {
        const ratioInput = document.getElementById(ratioId);
        const presetSelect = document.getElementById(presetId);
        
        presetSelect.addEventListener('change', (e) => {
          if (e.target.value) {
            ratioInput.value = e.target.value;
          }
        });

        ratioInput.addEventListener('input', (e) => {
          const val = e.target.value;
          const opts = Array.from(presetSelect.options).map(o => o.value);
          presetSelect.value = opts.includes(val) ? val : "";
        });
      };

      syncPreset('m1-ratio', 'm1-preset');
      syncPreset('m2-ratio', 'm2-preset');

      modeBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          modeBtns.forEach(b => {
            b.className = "mode-btn flex-1 bg-white border border-slate-200 text-slate-600 font-medium py-2 px-3 rounded-lg text-sm sm:text-base hover:bg-slate-50 transition-colors";
          });
          
          const activeBtn = e.target;
          activeBtn.className = "mode-btn flex-1 bg-[#1D9E75] text-white font-medium py-2 px-3 rounded-lg text-sm sm:text-base transition-colors border-transparent";
          
          currentMode = parseInt(activeBtn.getAttribute('data-mode'));
          modeForms.forEach((form, index) => {
            if (index + 1 === currentMode) {
              form.classList.remove('hidden');
              form.classList.add('block');
            } else {
              form.classList.add('hidden');
              form.classList.remove('block');
            }
          });
          
          resetCalculator();
        });
      });

      calcBtn.addEventListener('click', () => {
        errorMsg.classList.add('hidden');
        resultContainer.classList.add('hidden');
        
        try {
          if (currentMode === 1) {
            const real = parseFloat(document.getElementById('m1-real').value);
            const ratio = parseFloat(document.getElementById('m1-ratio').value);
            const unit = document.getElementById('m1-unit').value;
            const outUnit = document.getElementById('m1-out-unit').value;
            
            if (isNaN(real) || isNaN(ratio)) throw new Error('Please fill in all fields');
            if (real <= 0 || ratio <= 0) throw new Error('Please enter positive numbers only > 0');
            
            const realMeters = real * toMeters[unit];
            const scaleMeters = realMeters / ratio;
            const result = scaleMeters / toMeters[outUnit];
            
            resultText.innerHTML = `${result.toFixed(2)} <span class="text-xl text-slate-600 font-semibold ml-1">${outUnit}</span>`;
            
          } else if (currentMode === 2) {
            const scale = parseFloat(document.getElementById('m2-scale').value);
            const ratio = parseFloat(document.getElementById('m2-ratio').value);
            const unit = document.getElementById('m2-unit').value;
            const outUnit = document.getElementById('m2-out-unit').value;
            
            if (isNaN(scale) || isNaN(ratio)) throw new Error('Please fill in all fields');
            if (scale <= 0 || ratio <= 0) throw new Error('Please enter positive numbers only > 0');
            
            const scaleMeters = scale * toMeters[unit];
            const realMeters = scaleMeters * ratio;
            const result = realMeters / toMeters[outUnit];
            
            resultText.innerHTML = `${result.toFixed(2)} <span class="text-xl text-slate-600 font-semibold ml-1">${outUnit}</span>`;
            
          } else if (currentMode === 3) {
            const real = parseFloat(document.getElementById('m3-real').value);
            const realUnit = document.getElementById('m3-real-unit').value;
            const scale = parseFloat(document.getElementById('m3-scale').value);
            const scaleUnit = document.getElementById('m3-scale-unit').value;
            
            if (isNaN(real) || isNaN(scale)) throw new Error('Please fill in all fields');
            if (real <= 0 || scale <= 0) throw new Error('Please enter positive numbers only > 0');
            
            const realMeters = real * toMeters[realUnit];
            const scaleMeters = scale * toMeters[scaleUnit];
            
            const ratio = realMeters / scaleMeters;
            resultText.innerHTML = `<span class="text-2xl text-slate-600 font-semibold mr-1">1:</span>${ratio.toFixed(2)}`;
          }
          
          resultContainer.classList.remove('hidden');
        } catch (err) {
          errorMsg.textContent = err.message;
          errorMsg.classList.remove('hidden');
        }
      });

      const resetCalculator = () => {
        document.querySelectorAll('input[type="number"]').forEach(input => input.value = '');
        errorMsg.classList.add('hidden');
        resultContainer.classList.add('hidden');
      };

      resetBtn.addEventListener('click', resetCalculator);
    });
  </script>
</ToolLayout>