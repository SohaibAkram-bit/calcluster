---
import ToolLayout from '../../../Layouts/ToolLayout.astro';
import GradeCalculatorContent from '../../../components/content/GradeCalculatorContent.astro';

const title = "Grade Calculator | Weighted GPA & What-If Scores Free ";
const description = "Use this free Grade Calculator to calculate weighted grades, GPA, what-if scores, and letter grades. Fast, private, and works on any device.";
const canonicalUrl = "https://calcluster.com/tools/grade-calculator/";
const relatedTools = [
  { name: "Percent Increase Calculator", link: "/tools/percent-increase/" },
  { name: "Percent Decrease Calculator", link: "/tools/percent-decrease/" },
  { name: "Treadmill Calorie Calculator", link: "/tools/treadmill-calorie-calculator/" }
];
---

<ToolLayout title={title} description={description} canonicalUrl={canonicalUrl} relatedTools={relatedTools}>
  <div class="max-w-5xl mx-auto px-4 py-8">

    <h1 class="text-3xl font-bold text-slate-900 mb-2">Grade Calculator</h1>
    <p class="text-slate-600 mb-8">Calculate weighted grades, GPA, and what-if scenarios instantly.</p>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 mb-8">
      <!-- LEFT: Calculator -->
      <div class="lg:col-span-3">
        
        <!-- Tab Switcher -->
        <div class="grid grid-cols-2 sm:flex sm:flex-row gap-2 mb-6" id="tab-buttons">
          <button data-tab="1" class="tab-btn w-full min-h-[48px] px-4 font-semibold rounded-lg bg-[#1D9E75] text-white transition-colors">Weighted Grade</button>
          <button data-tab="2" class="tab-btn w-full min-h-[48px] px-4 font-semibold rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">GPA</button>
          <button data-tab="3" class="tab-btn w-full min-h-[48px] px-4 font-semibold rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">What-If</button>
          <button data-tab="4" class="tab-btn w-full min-h-[48px] px-4 font-semibold rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">Letter Grade</button>
        </div>

        <!-- TAB 1: Weighted Grade -->
        <div id="tab-1" class="tab-content bg-slate-50 border border-slate-200 rounded-xl shadow-sm p-4 sm:p-6 relative">
          
          <!-- Header inside Tab 1 -->
          <div class="mb-4">
            <button id="btn-add-row" class="w-full min-h-[48px] mb-3 border-2 border-[#1D9E75] text-[#1D9E75] hover:bg-[#1D9E75] hover:text-white font-semibold rounded-lg transition-colors">
              + Add Category
            </button>
            <div id="weight-badge" class="w-full bg-amber-50 text-amber-700 border border-amber-200 rounded px-3 py-2 text-sm font-medium text-center transition-colors">
              Total weight: 0% (must equal 100%)
            </div>
          </div>

          <!-- Rows Container -->
          <div id="rows-container" class="space-y-3 mb-6">
            <!-- Injected by JS -->
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col gap-3">
            <button id="btn-calc" class="w-full min-h-[48px] bg-[#1D9E75] hover:bg-[#168561] text-white font-semibold rounded-lg transition-colors">
              Calculate Grade
            </button>
            <button id="btn-reset" class="w-full min-h-[48px] bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold rounded-lg transition-colors">
              Reset
            </button>
          </div>

          <!-- Error Message -->
          <div id="error-msg" class="hidden mt-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm text-center"></div>

          <!-- Results Area -->
          <div id="result-area" class="hidden mt-6 p-6 bg-white border border-[#1D9E75] rounded-xl shadow-sm text-center">
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wide mb-1">Final Grade</div>
            <div id="result-percent" class="text-4xl sm:text-5xl font-bold text-slate-900 mb-3">--%</div>
            <div class="text-slate-600 font-medium">Letter Grade: <span id="result-letter" class="inline-block px-3 py-1 ml-1 bg-slate-100 text-slate-800 text-lg font-bold rounded-lg border border-slate-200">--</span></div>
          </div>

        </div>

        <!-- TAB 2: GPA Calculator -->
        <div id="tab-2" class="tab-content hidden bg-slate-50 border border-slate-200 rounded-xl shadow-sm p-4 sm:p-6 relative">
          
          <!-- Scale Selector -->
          <div class="mb-4">
            <label for="gpa-scale" class="block text-sm font-medium text-slate-700 mb-1">Grading Scale</label>
            <select id="gpa-scale" class="w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#1D9E75]">
              <option value="4.0" selected>4.0 Scale (US Standard)</option>
              <option value="4.3">4.3 Scale (US, with A+)</option>
              <option value="5.0">5.0 Scale (International)</option>
              <option value="10.0">10.0 Scale (India/Pakistan)</option>
            </select>
          </div>

          <!-- Header inside Tab 2 -->
          <div class="mb-4">
            <button id="btn-add-course" class="w-full min-h-[48px] mb-3 border-2 border-[#1D9E75] text-[#1D9E75] hover:bg-[#1D9E75] hover:text-white font-semibold rounded-lg transition-colors">
              + Add Course
            </button>
          </div>

          <!-- Rows Container -->
          <div id="course-rows-container" class="space-y-3 mb-6">
            <!-- Injected by JS -->
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col gap-3">
            <button id="btn-calc-gpa" class="w-full min-h-[48px] bg-[#1D9E75] hover:bg-[#168561] text-white font-semibold rounded-lg transition-colors">
              Calculate GPA
            </button>
            <button id="btn-reset-gpa" class="w-full min-h-[48px] bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold rounded-lg transition-colors">
              Reset
            </button>
          </div>

          <!-- Error Message -->
          <div id="error-msg-gpa" class="hidden mt-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm text-center"></div>

          <!-- Results Area -->
          <div id="result-area-gpa" class="hidden mt-6 p-6 bg-white border border-[#1D9E75] rounded-xl shadow-sm text-center">
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wide mb-1">Cumulative GPA</div>
            <div id="result-gpa" class="text-4xl sm:text-5xl font-bold text-slate-900 mb-1">--</div>
            <div id="result-scale" class="text-slate-500 font-medium mb-3">out of 4.0</div>
            <div class="text-slate-600 font-medium">Total Credits: <span id="result-credits" class="inline-block px-3 py-1 ml-1 bg-slate-100 text-slate-800 text-lg font-bold rounded-lg border border-slate-200">--</span></div>
          </div>

        </div>
        
        <!-- TAB 3: What-If Calculator -->
        <div id="tab-3" class="tab-content hidden bg-slate-50 border border-slate-200 rounded-xl shadow-sm p-4 sm:p-6 relative">
          
          <!-- Inputs Card -->
          <div class="bg-white border border-slate-200 rounded-lg p-4 sm:p-6 space-y-4 mb-6">
            <div>
              <label for="whatif-current" class="block text-sm font-medium text-slate-700 mb-1">Your Current Grade (%)</label>
              <input type="number" id="whatif-current" inputmode="decimal" min="0" step="any" placeholder="85" class="w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
            </div>
            <div>
              <label for="whatif-completed" class="block text-sm font-medium text-slate-700 mb-1">Weight Already Completed (%)</label>
              <input type="number" id="whatif-completed" inputmode="decimal" min="0.01" max="99.99" step="any" placeholder="70" class="w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
            </div>
            <div>
              <label for="whatif-target" class="block text-sm font-medium text-slate-700 mb-1">Target Final Grade (%)</label>
              <input type="number" id="whatif-target" inputmode="decimal" min="0" step="any" placeholder="90" class="w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col gap-3">
            <button id="btn-calc-whatif" class="w-full min-h-[48px] bg-[#1D9E75] hover:bg-[#168561] text-white font-semibold rounded-lg transition-colors">
              Calculate
            </button>
            <button id="btn-reset-whatif" class="w-full min-h-[48px] bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold rounded-lg transition-colors">
              Reset
            </button>
          </div>

          <!-- Error Message -->
          <div id="error-msg-whatif" class="hidden mt-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm text-center"></div>

          <!-- Results Area -->
          <div id="result-area-whatif" class="hidden mt-6 p-6 bg-white border border-[#1D9E75] rounded-xl shadow-sm text-center transition-colors">
            <div class="text-sm font-medium text-slate-500 uppercase tracking-wide mb-1">Score Needed on Remaining Work</div>
            <div id="result-score-needed" class="text-4xl sm:text-5xl font-bold text-slate-900 mb-1 transition-colors">--%</div>
            <div id="result-whatif-message" class="hidden mt-2 mb-2 text-sm font-medium"></div>
            <div id="result-remaining-weight" class="text-slate-600 font-medium mt-3">Remaining Weight: --%</div>
          </div>

        </div>
        
        <!-- TAB 4: Letter Grade Converter -->
        <div id="tab-4" class="tab-content hidden bg-slate-50 border border-slate-200 rounded-xl shadow-sm p-4 sm:p-6 relative">
          
          <!-- Scale Selector -->
          <div class="mb-4">
            <label for="letter-scale" class="block text-sm font-medium text-slate-700 mb-1">Grading Scale</label>
            <select id="letter-scale" class="w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#1D9E75]">
              <option value="standard" selected>Standard (90/80/70/60)</option>
              <option value="plusminus">Plus/Minus (A+/A/A-, etc.)</option>
            </select>
          </div>

          <!-- Inputs Card -->
          <div class="bg-white border border-slate-200 rounded-lg p-4 sm:p-6 mb-6">
            <!-- Sub-tabs -->
            <div class="grid grid-cols-2 gap-2 mb-4">
              <button id="letter-subtab-pct" class="w-full min-h-[44px] px-2 text-sm font-semibold rounded-lg bg-[#1D9E75] text-white transition-colors">% → Letter</button>
              <button id="letter-subtab-letter" class="w-full min-h-[44px] px-2 text-sm font-semibold rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors">Letter → %</button>
            </div>

            <!-- Mode: % -> Letter -->
            <div id="letter-mode-pct" class="space-y-1">
              <label for="letter-pct-input" class="block text-sm font-medium text-slate-700 mb-1">Percentage</label>
              <input type="number" id="letter-pct-input" inputmode="decimal" min="0" max="100" step="any" placeholder="85" class="w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
            </div>

            <!-- Mode: Letter -> % -->
            <div id="letter-mode-letter" class="space-y-1 hidden">
              <label for="letter-grade-select" class="block text-sm font-medium text-slate-700 mb-1">Letter Grade</label>
              <select id="letter-grade-select" class="w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#1D9E75]">
                <!-- populated by JS -->
              </select>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-col gap-3">
            <button id="btn-convert-letter" class="w-full min-h-[48px] bg-[#1D9E75] hover:bg-[#168561] text-white font-semibold rounded-lg transition-colors">
              Convert
            </button>
            <button id="btn-reset-letter" class="w-full min-h-[48px] bg-slate-200 hover:bg-slate-300 text-slate-700 font-semibold rounded-lg transition-colors">
              Reset
            </button>
          </div>

          <!-- Error Message -->
          <div id="error-msg-letter" class="hidden mt-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm text-center"></div>

          <!-- Results Area -->
          <div id="result-area-letter" class="hidden mt-6 p-6 bg-white border border-[#1D9E75] rounded-xl shadow-sm text-center transition-colors">
            <div id="result-letter-label" class="text-sm font-medium text-slate-500 uppercase tracking-wide mb-1">Letter Grade</div>
            <div id="result-letter-display" class="text-4xl sm:text-5xl font-bold text-slate-900 mb-1 transition-colors">--</div>
            <div id="result-letter-range" class="text-slate-600 font-medium mt-3">Range: --</div>
          </div>

        </div>

      </div>
      <!-- end left column -->

      <!-- RIGHT: Ad Sidebar -->
      <div class="lg:col-span-2 flex justify-center items-start pt-2">
        <div class="w-[300px] h-[250px] bg-slate-100 border border-slate-200 rounded flex items-center justify-center text-slate-400 text-sm">Advertisement</div>
      </div>

    </div>

    <!-- In-content ad -->
    <div class="w-full h-[90px] bg-slate-100 border border-slate-200 rounded flex items-center justify-center text-slate-400 text-sm my-8">Advertisement</div>

    <GradeCalculatorContent />

    <!-- Bottom ad -->
    <div class="w-full h-[90px] bg-slate-100 border border-slate-200 rounded flex items-center justify-center text-slate-400 text-sm my-8">Advertisement</div>

  </div>

  <!-- Template for Row -->
  <template id="row-template">
    <div class="category-row relative bg-white border border-slate-200 rounded-lg p-4 pt-12 sm:pt-4">
      <!-- Delete button -->
      <button type="button" class="btn-delete absolute top-1 right-1 w-[44px] h-[44px] flex items-center justify-center text-slate-400 rounded transition-colors" aria-label="Remove category">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </button>
      
      <div class="flex flex-col sm:flex-row gap-3">
        <div class="flex-1">
          <label class="block text-sm font-medium text-slate-700 mb-1">Category Name</label>
          <input type="text" placeholder="e.g. Homework" class="input-name w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
        </div>
        <div class="w-full sm:w-28">
          <label class="block text-sm font-medium text-slate-700 mb-1">Score (%)</label>
          <input type="number" inputmode="decimal" min="0" step="any" placeholder="95" class="input-score w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
        </div>
        <div class="w-full sm:w-28">
          <label class="block text-sm font-medium text-slate-700 mb-1">Weight (%)</label>
          <input type="number" inputmode="decimal" min="0" step="any" placeholder="20" class="input-weight w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
        </div>
      </div>
    </div>
  </template>

  <!-- Template for Course Row (Tab 2) -->
  <template id="course-row-template">
    <div class="course-row relative bg-white border border-slate-200 rounded-lg p-4 pt-12 sm:pt-4">
      <!-- Delete button -->
      <button type="button" class="btn-delete-course absolute top-1 right-1 w-[44px] h-[44px] flex items-center justify-center text-slate-400 rounded transition-colors hover:bg-red-50 hover:text-red-500" aria-label="Remove course">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
        </svg>
      </button>
      
      <div class="flex flex-col sm:flex-row gap-3">
        <div class="flex-1">
          <label class="block text-sm font-medium text-slate-700 mb-1">Course Name</label>
          <input type="text" placeholder="e.g. Calculus I" class="input-course-name w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
        </div>
        <div class="w-full sm:w-28">
          <label class="block text-sm font-medium text-slate-700 mb-1">Grade</label>
          <select class="input-course-grade w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 bg-white focus:outline-none focus:ring-2 focus:ring-[#1D9E75]">
            <!-- Options populated by JS -->
          </select>
        </div>
        <div class="w-full sm:w-28">
          <label class="block text-sm font-medium text-slate-700 mb-1">Credits</label>
          <input type="number" inputmode="decimal" min="0.5" step="any" placeholder="3" class="input-course-credits w-full min-h-[48px] text-base border border-slate-300 rounded-lg px-3 py-2 text-slate-900 focus:outline-none focus:ring-2 focus:ring-[#1D9E75]" />
        </div>
      </div>
    </div>
  </template>

  <script>
    (function() {
      // --- Tab Switching logic ---
      const tabBtns = document.querySelectorAll('.tab-btn');
      const tabContents = document.querySelectorAll('.tab-content');
      
      tabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-tab');
          
          tabBtns.forEach(b => {
            if (b.getAttribute('data-tab') === target) {
              b.className = 'tab-btn w-full min-h-[48px] px-4 font-semibold rounded-lg bg-[#1D9E75] text-white transition-colors';
            } else {
              b.className = 'tab-btn w-full min-h-[48px] px-4 font-semibold rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors';
            }
          });
          
          tabContents.forEach(c => {
            if (c.id === `tab-${target}`) {
              c.classList.remove('hidden');
            } else {
              c.classList.add('hidden');
            }
          });
        });
      });

      // --- Tab 1 Logic (Weighted Grade) ---
      const rowsContainer = document.getElementById('rows-container');
      const btnAdd = document.getElementById('btn-add-row');
      const btnCalc = document.getElementById('btn-calc');
      const btnReset = document.getElementById('btn-reset');
      const weightBadge = document.getElementById('weight-badge');
      const template = document.getElementById('row-template');
      const errorMsg = document.getElementById('error-msg');
      const resultArea = document.getElementById('result-area');
      const resultPercent = document.getElementById('result-percent');
      const resultLetter = document.getElementById('result-letter');

      function updateBadge() {
        let sum = 0;
        document.querySelectorAll('.input-weight').forEach(input => {
          const val = parseFloat(input.value);
          if (!isNaN(val)) sum += val;
        });
        
        // Fix float precision issues (e.g. 33.3 * 3 = 99.9)
        sum = Math.round(sum * 100) / 100;
        
        if (sum === 100) {
          weightBadge.className = 'w-full bg-emerald-50 text-emerald-700 border border-emerald-200 rounded px-3 py-2 text-sm font-medium text-center transition-colors';
          weightBadge.textContent = `Total weight: ${sum}% (Perfect!)`;
        } else {
          weightBadge.className = 'w-full bg-amber-50 text-amber-700 border border-amber-200 rounded px-3 py-2 text-sm font-medium text-center transition-colors';
          weightBadge.textContent = `Total weight: ${sum}% (must equal 100%)`;
        }
        
        // Enforce minimum 1 row layout logic
        const rows = document.querySelectorAll('.category-row');
        rows.forEach(row => {
          const delBtn = row.querySelector('.btn-delete');
          if (rows.length <= 1) {
            delBtn.disabled = true;
            delBtn.classList.add('opacity-30', 'cursor-not-allowed');
            delBtn.classList.remove('hover:bg-red-50', 'hover:text-red-500');
          } else {
            delBtn.disabled = false;
            delBtn.classList.remove('opacity-30', 'cursor-not-allowed');
            delBtn.classList.add('hover:bg-red-50', 'hover:text-red-500');
          }
        });
      }

      function addRow() {
        const clone = template.content.cloneNode(true);
        const row = clone.querySelector('.category-row');
        
        const inputs = row.querySelectorAll('input');
        inputs.forEach(input => {
          if (input.classList.contains('input-weight')) {
            input.addEventListener('input', updateBadge);
          }
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') calculate();
          });
        });
        
        const delBtn = row.querySelector('.btn-delete');
        delBtn.addEventListener('click', () => {
          row.remove();
          updateBadge();
        });
        
        rowsContainer.appendChild(clone);
        updateBadge();
      }

      function getLetterGrade(percent) {
        if (percent >= 90) return 'A';
        if (percent >= 80) return 'B';
        if (percent >= 70) return 'C';
        if (percent >= 60) return 'D';
        return 'F';
      }

      function showError(msg) {
        errorMsg.textContent = msg;
        errorMsg.classList.remove('hidden');
        resultArea.classList.add('hidden');
      }

      function calculate() {
        errorMsg.classList.add('hidden');
        const rows = document.querySelectorAll('.category-row');
        let totalWeight = 0;
        let weightedScoreSum = 0;
        let hasValidRow = false;
        
        for (const row of rows) {
          const scoreStr = row.querySelector('.input-score').value;
          const weightStr = row.querySelector('.input-weight').value;
          
          // Skip rows without score and weight entirely
          if (scoreStr.trim() === '' && weightStr.trim() === '') continue;
          
          const score = parseFloat(scoreStr);
          const weight = parseFloat(weightStr);
          
          if (isNaN(score) || isNaN(weight)) {
             return showError('Please enter both Score and Weight for active rows.');
          }
          if (score < 0 || weight <= 0) {
             return showError('Scores cannot be negative, and weights must be greater than 0.');
          }
          
          totalWeight += weight;
          weightedScoreSum += (score * weight);
          hasValidRow = true;
        }
        
        if (!hasValidRow) {
          return showError('Please fill out at least one row to calculate.');
        }
        if (totalWeight === 0) {
          return showError('Total weight must be greater than 0.');
        }
        
        // Standard weighted average normalizes out of the total inputted weight
        const finalPercent = weightedScoreSum / totalWeight;
        
        resultPercent.textContent = parseFloat(finalPercent.toFixed(2)) + '%';
        resultLetter.textContent = getLetterGrade(finalPercent);
        resultArea.classList.remove('hidden');
        
        // Simple smooth scroll on small devices if result is far down
        if (window.innerWidth < 640) {
           resultArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      function reset() {
        rowsContainer.innerHTML = '';
        addRow();
        addRow();
        errorMsg.classList.add('hidden');
        resultArea.classList.add('hidden');
        updateBadge();
      }

      // --- Initialization ---
      btnAdd.addEventListener('click', addRow);
      btnCalc.addEventListener('click', calculate);
      btnReset.addEventListener('click', reset);
      
      // Populate default state
      reset();

      // --- Tab 2 Logic (GPA Calculator) ---
      const gradeScales = {
        "4.0": { "A": 4.0, "A-": 3.7, "B+": 3.3, "B": 3.0, "B-": 2.7, "C+": 2.3, "C": 2.0, "C-": 1.7, "D+": 1.3, "D": 1.0, "F": 0.0 },
        "4.3": { "A+": 4.3, "A": 4.0, "A-": 3.7, "B+": 3.3, "B": 3.0, "B-": 2.7, "C+": 2.3, "C": 2.0, "C-": 1.7, "D+": 1.3, "D": 1.0, "F": 0.0 },
        "5.0": { "A": 5.0, "B": 4.0, "C": 3.0, "D": 2.0, "E": 1.0, "F": 0.0 },
        "10.0": { "O": 10.0, "A+": 9.0, "A": 8.0, "B+": 7.0, "B": 6.0, "C": 5.0, "D": 4.0, "F": 0.0 }
      };

      const gpaScaleSelect = document.getElementById('gpa-scale');
      const courseRowsContainer = document.getElementById('course-rows-container');
      const btnAddCourse = document.getElementById('btn-add-course');
      const btnCalcGpa = document.getElementById('btn-calc-gpa');
      const btnResetGpa = document.getElementById('btn-reset-gpa');
      const courseTemplate = document.getElementById('course-row-template');
      const errorMsgGpa = document.getElementById('error-msg-gpa');
      const resultAreaGpa = document.getElementById('result-area-gpa');
      const resultGpa = document.getElementById('result-gpa');
      const resultScale = document.getElementById('result-scale');
      const resultCredits = document.getElementById('result-credits');

      function updateCourseDeleteButtons() {
        const rows = document.querySelectorAll('.course-row');
        rows.forEach(row => {
          const delBtn = row.querySelector('.btn-delete-course');
          if (rows.length <= 1) {
            delBtn.disabled = true;
            delBtn.classList.add('opacity-30', 'cursor-not-allowed');
            delBtn.classList.remove('hover:bg-red-50', 'hover:text-red-500');
          } else {
            delBtn.disabled = false;
            delBtn.classList.remove('opacity-30', 'cursor-not-allowed');
            delBtn.classList.add('hover:bg-red-50', 'hover:text-red-500');
          }
        });
      }

      function populateGradeDropdown(selectEl, retainValue = false) {
        const scale = gpaScaleSelect.value;
        const grades = gradeScales[scale];
        const currentVal = selectEl.value;
        
        selectEl.innerHTML = '<option value="">--</option>';
        for (const [letter, value] of Object.entries(grades)) {
          const opt = document.createElement('option');
          opt.value = letter;
          opt.textContent = letter;
          selectEl.appendChild(opt);
        }
        
        if (retainValue && grades[currentVal] !== undefined) {
          selectEl.value = currentVal;
        }
      }

      function addCourseRow() {
        const clone = courseTemplate.content.cloneNode(true);
        const row = clone.querySelector('.course-row');
        
        const gradeSelect = row.querySelector('.input-course-grade');
        populateGradeDropdown(gradeSelect);

        const inputs = row.querySelectorAll('input, select');
        inputs.forEach(input => {
          input.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') calculateGpa();
          });
        });
        
        const delBtn = row.querySelector('.btn-delete-course');
        delBtn.addEventListener('click', () => {
          row.remove();
          updateCourseDeleteButtons();
        });
        
        courseRowsContainer.appendChild(clone);
        updateCourseDeleteButtons();
      }

      function showErrorGpa(msg) {
        errorMsgGpa.textContent = msg;
        errorMsgGpa.classList.remove('hidden');
        resultAreaGpa.classList.add('hidden');
      }

      function calculateGpa() {
        errorMsgGpa.classList.add('hidden');
        const rows = document.querySelectorAll('.course-row');
        const scale = gpaScaleSelect.value;
        const grades = gradeScales[scale];
        
        let totalCredits = 0;
        let totalPoints = 0;
        let hasValidRow = false;
        
        for (const row of rows) {
          const gradeLetter = row.querySelector('.input-course-grade').value;
          const creditsStr = row.querySelector('.input-course-credits').value;
          const nameStr = row.querySelector('.input-course-name').value;
          
          if (gradeLetter === '' && creditsStr.trim() === '' && nameStr.trim() === '') continue;
          
          if (gradeLetter !== '' && creditsStr.trim() === '') {
            return showErrorGpa('Credit hours must be greater than 0 for all courses.');
          }
          if (gradeLetter === '' && creditsStr.trim() !== '') {
             return showErrorGpa('Please select a grade for all courses with credit hours.');
          }
          
          const credits = parseFloat(creditsStr);
          if (isNaN(credits) || credits <= 0) {
            return showErrorGpa('Credit hours must be greater than 0 for all courses.');
          }
          
          const points = grades[gradeLetter];
          totalCredits += credits;
          totalPoints += (points * credits);
          hasValidRow = true;
        }
        
        if (!hasValidRow) {
          return showErrorGpa('Please add at least one course with grade and credit hours.');
        }
        
        const finalGpa = totalPoints / totalCredits;
        
        resultGpa.textContent = finalGpa.toFixed(2);
        resultScale.textContent = `out of ${scale}`;
        resultCredits.textContent = totalCredits;
        resultAreaGpa.classList.remove('hidden');
        
        if (window.innerWidth < 640) {
           resultAreaGpa.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      function resetGpa() {
        gpaScaleSelect.value = "4.0";
        courseRowsContainer.innerHTML = '';
        addCourseRow();
        addCourseRow();
        errorMsgGpa.classList.add('hidden');
        resultAreaGpa.classList.add('hidden');
      }

      // --- GPA Init & Events ---
      gpaScaleSelect.addEventListener('change', () => {
        const gradeSelects = document.querySelectorAll('.input-course-grade');
        gradeSelects.forEach(select => populateGradeDropdown(select, true));
        if (!resultAreaGpa.classList.contains('hidden')) {
          calculateGpa();
        }
      });

      btnAddCourse.addEventListener('click', addCourseRow);
      btnCalcGpa.addEventListener('click', calculateGpa);
      btnResetGpa.addEventListener('click', resetGpa);
      
      resetGpa();

      // --- Tab 3 Logic (What-If Calculator) ---
      const inputCurrent = document.getElementById('whatif-current');
      const inputCompleted = document.getElementById('whatif-completed');
      const inputTarget = document.getElementById('whatif-target');
      const btnCalcWhatif = document.getElementById('btn-calc-whatif');
      const btnResetWhatif = document.getElementById('btn-reset-whatif');
      const errorMsgWhatif = document.getElementById('error-msg-whatif');
      const resultAreaWhatif = document.getElementById('result-area-whatif');
      const resultScoreNeeded = document.getElementById('result-score-needed');
      const resultRemainingWeight = document.getElementById('result-remaining-weight');
      const resultWhatifMessage = document.getElementById('result-whatif-message');

      function showErrorWhatif(msg) {
        errorMsgWhatif.textContent = msg;
        errorMsgWhatif.classList.remove('hidden');
        resultAreaWhatif.classList.add('hidden');
      }

      function calculateWhatif() {
        errorMsgWhatif.classList.add('hidden');
        const currentStr = inputCurrent.value;
        const completedStr = inputCompleted.value;
        const targetStr = inputTarget.value;
        
        if (currentStr.trim() === '' || completedStr.trim() === '' || targetStr.trim() === '') {
          return showErrorWhatif('Please fill in all fields.');
        }
        
        const current = parseFloat(currentStr);
        const completed = parseFloat(completedStr);
        const target = parseFloat(targetStr);
        
        if (isNaN(current) || current < 0 || current > 100) {
          return showErrorWhatif('Current grade must be between 0 and 100.');
        }
        if (isNaN(completed) || completed <= 0 || completed >= 100) {
          return showErrorWhatif('Weight completed must be between 0 and 100 (exclusive).');
        }
        if (isNaN(target) || target < 0 || target > 100) {
          return showErrorWhatif('Target grade must be between 0 and 100.');
        }
        
        const weightRemaining = 100 - completed;
        let scoreNeeded = (target - (current * completed / 100)) / (weightRemaining / 100);
        
        scoreNeeded = Math.round(scoreNeeded * 100) / 100;
        const roundedRemaining = Math.round(weightRemaining * 100) / 100;
        
        // Reset to normal state
        resultAreaWhatif.className = 'hidden mt-6 p-6 bg-white border border-[#1D9E75] rounded-xl shadow-sm text-center transition-colors';
        resultScoreNeeded.className = 'text-4xl sm:text-5xl font-bold text-slate-900 mb-1 transition-colors';
        resultWhatifMessage.className = 'hidden mt-2 mb-2 text-sm font-medium';
        
        if (scoreNeeded > 100) {
          resultAreaWhatif.classList.replace('border-[#1D9E75]', 'border-amber-400');
          resultScoreNeeded.classList.replace('text-slate-900', 'text-amber-600');
          resultScoreNeeded.textContent = `${scoreNeeded}%`;
          resultWhatifMessage.textContent = "⚠️ This target may not be achievable — even a perfect score won't be enough.";
          resultWhatifMessage.classList.add('text-amber-700');
          resultWhatifMessage.classList.remove('hidden');
        } else if (scoreNeeded <= 0) {
          resultScoreNeeded.textContent = "0%";
          resultWhatifMessage.textContent = "✅ You've already secured this grade or better!";
          resultWhatifMessage.classList.add('text-emerald-600');
          resultWhatifMessage.classList.remove('hidden');
        } else {
          resultScoreNeeded.textContent = `${scoreNeeded}%`;
        }
        
        resultRemainingWeight.textContent = `Remaining Weight: ${roundedRemaining}%`;
        resultAreaWhatif.classList.remove('hidden');
        
        if (window.innerWidth < 640) {
           resultAreaWhatif.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      function resetWhatif() {
        inputCurrent.value = '';
        inputCompleted.value = '';
        inputTarget.value = '';
        errorMsgWhatif.classList.add('hidden');
        resultAreaWhatif.classList.add('hidden');
      }

      // --- What-If Init & Events ---
      [inputCurrent, inputCompleted, inputTarget].forEach(input => {
        input.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') calculateWhatif();
        });
      });
      
      btnCalcWhatif.addEventListener('click', calculateWhatif);
      btnResetWhatif.addEventListener('click', resetWhatif);

      // --- Tab 4 Logic (Letter Grade Converter) ---
      const letterScales = {
        standard: [
          { letter: "A", min: 90, max: 100 },
          { letter: "B", min: 80, max: 89.99 },
          { letter: "C", min: 70, max: 79.99 },
          { letter: "D", min: 60, max: 69.99 },
          { letter: "F", min: 0,  max: 59.99 }
        ],
        plusminus: [
          { letter: "A+", min: 97, max: 100 },
          { letter: "A",  min: 93, max: 96.99 },
          { letter: "A-", min: 90, max: 92.99 },
          { letter: "B+", min: 87, max: 89.99 },
          { letter: "B",  min: 83, max: 86.99 },
          { letter: "B-", min: 80, max: 82.99 },
          { letter: "C+", min: 77, max: 79.99 },
          { letter: "C",  min: 73, max: 76.99 },
          { letter: "C-", min: 70, max: 72.99 },
          { letter: "D+", min: 67, max: 69.99 },
          { letter: "D",  min: 63, max: 66.99 },
          { letter: "D-", min: 60, max: 62.99 },
          { letter: "F",  min: 0,  max: 59.99 }
        ]
      };

      const letterScaleSelect = document.getElementById('letter-scale');
      const subtabPct = document.getElementById('letter-subtab-pct');
      const subtabLetter = document.getElementById('letter-subtab-letter');
      const modePctContainer = document.getElementById('letter-mode-pct');
      const modeLetterContainer = document.getElementById('letter-mode-letter');
      const inputPct = document.getElementById('letter-pct-input');
      const selectGrade = document.getElementById('letter-grade-select');
      const btnConvertLetter = document.getElementById('btn-convert-letter');
      const btnResetLetter = document.getElementById('btn-reset-letter');
      const errorMsgLetter = document.getElementById('error-msg-letter');
      const resultAreaLetter = document.getElementById('result-area-letter');
      const resultLabelLetter = document.getElementById('result-letter-label');
      const resultDisplayLetter = document.getElementById('result-letter-display');
      const resultRangeLetter = document.getElementById('result-letter-range');

      let currentLetterMode = 'pct'; // 'pct' or 'letter'

      function populateLetterDropdown(retainValue = false) {
        const scale = letterScaleSelect.value;
        const grades = letterScales[scale];
        const currentVal = selectGrade.value;
        
        selectGrade.innerHTML = '';
        grades.forEach(g => {
          const opt = document.createElement('option');
          opt.value = g.letter;
          opt.textContent = g.letter;
          selectGrade.appendChild(opt);
        });
        
        if (retainValue && currentVal) {
          const exists = grades.some(g => g.letter === currentVal);
          if (exists) {
            selectGrade.value = currentVal;
          } else {
            selectGrade.selectedIndex = 0;
          }
        }
      }

      function switchLetterMode(mode) {
        currentLetterMode = mode;
        errorMsgLetter.classList.add('hidden');
        resultAreaLetter.classList.add('hidden');
        
        if (mode === 'pct') {
          subtabPct.className = 'w-full min-h-[44px] px-2 text-sm font-semibold rounded-lg bg-[#1D9E75] text-white transition-colors';
          subtabLetter.className = 'w-full min-h-[44px] px-2 text-sm font-semibold rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors';
          modePctContainer.classList.remove('hidden');
          modeLetterContainer.classList.add('hidden');
        } else {
          subtabLetter.className = 'w-full min-h-[44px] px-2 text-sm font-semibold rounded-lg bg-[#1D9E75] text-white transition-colors';
          subtabPct.className = 'w-full min-h-[44px] px-2 text-sm font-semibold rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 transition-colors';
          modeLetterContainer.classList.remove('hidden');
          modePctContainer.classList.add('hidden');
        }
      }

      function showErrorLetter(msg) {
        errorMsgLetter.textContent = msg;
        errorMsgLetter.classList.remove('hidden');
        resultAreaLetter.classList.add('hidden');
      }

      function convertLetter() {
        errorMsgLetter.classList.add('hidden');
        const scale = letterScaleSelect.value;
        const grades = letterScales[scale];

        if (currentLetterMode === 'pct') {
          const pctStr = inputPct.value;
          if (pctStr.trim() === '') return showErrorLetter('Please enter a percentage.');
          
          const pct = parseFloat(pctStr);
          if (isNaN(pct) || pct < 0 || pct > 100) return showErrorLetter('Percentage must be between 0 and 100.');

          // Find matching grade (sorted highest to lowest)
          let matchedGrade = grades[grades.length - 1];
          for (const g of grades) {
            if (pct >= g.min) {
              matchedGrade = g;
              break;
            }
          }

          resultLabelLetter.textContent = 'Letter Grade';
          resultDisplayLetter.className = 'text-4xl sm:text-5xl font-bold text-slate-900 mb-1 transition-colors';
          resultDisplayLetter.textContent = matchedGrade.letter;
          resultRangeLetter.textContent = `Range: ${matchedGrade.min}% – ${matchedGrade.max === 100 ? '100' : matchedGrade.max}%`;

        } else {
          const selectedLetter = selectGrade.value;
          const matchedGrade = grades.find(g => g.letter === selectedLetter);
          
          if (!matchedGrade) return showErrorLetter('Invalid letter grade selected.');

          resultLabelLetter.textContent = 'Percentage Range';
          resultDisplayLetter.className = 'text-3xl sm:text-4xl font-bold text-slate-900 mb-1 transition-colors';
          resultDisplayLetter.textContent = `${matchedGrade.min}% – ${matchedGrade.max === 100 ? '100' : matchedGrade.max}%`;
          resultRangeLetter.textContent = `Letter Grade: ${matchedGrade.letter}`;
        }

        resultAreaLetter.classList.remove('hidden');
        if (window.innerWidth < 640) {
           resultAreaLetter.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      function resetLetter() {
        letterScaleSelect.value = 'standard';
        populateLetterDropdown();
        inputPct.value = '';
        switchLetterMode('pct');
        errorMsgLetter.classList.add('hidden');
        resultAreaLetter.classList.add('hidden');
      }

      // --- Tab 4 Init & Events ---
      subtabPct.addEventListener('click', () => switchLetterMode('pct'));
      subtabLetter.addEventListener('click', () => switchLetterMode('letter'));
      
      letterScaleSelect.addEventListener('change', () => {
        populateLetterDropdown(true);
        if (!resultAreaLetter.classList.contains('hidden')) {
          convertLetter();
        }
      });

      inputPct.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') convertLetter();
      });
      selectGrade.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') convertLetter();
      });

      btnConvertLetter.addEventListener('click', convertLetter);
      btnResetLetter.addEventListener('click', resetLetter);

      // Initialize
      populateLetterDropdown();
    })();
  </script>
</ToolLayout>