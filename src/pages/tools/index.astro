---
import ToolLayout from '../../Layouts/ToolLayout.astro';

const mathTools = [
  {
    name: "Scale Calculator",
    link: "/tools/scale-calculator/",
    description: "Convert between real sizes and scale models instantly."
  },
  {
    name: "Percent Increase Calculator",
    link: "/tools/percent-increase/",
    description: "Find the percentage growth between any two numbers."
  },
  {
    name: "Percent Decrease Calculator",
    link: "/tools/percent-decrease/",
    description: "Find the percentage drop between an original and a new value."
  },
  {
    name: "Right Triangle Calculator",
    link: "/tools/right-triangle/",
    description: "Solve any right triangle — find sides, angles, area, and altitude from any 2 known values."
  }
];

const scienceTools = [
  {
    name: "pH Calculator",
    link: "/tools/ph-calculator/",
    description: "Instantly calculate pH, pOH, hydrogen ion concentration [H+], and hydroxide ion concentration [OH-]."
  }
];

const academicsTools = [
  {
    name: "Grade Calculator",
    link: "/tools/grade-calculator/",
    description: "Calculate weighted grades, GPA, what-if scenarios, and convert letter grades."
  }
];

const healthFitnessTools = [
  {
    name: "RPE Calculator",
    link: "/tools/rpe-calculator/",
    description: "Calculate working weight from RPE, estimate your 1RM, or browse the full RPE percentage chart."
  },
  {
    name: "Treadmill Calorie Calculator",
    link: "/tools/treadmill-calorie-calculator/",
    description: "Calculate calories burned by speed, incline, weight, and duration. Includes pace calculator and MET reference table.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#1D9E75]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 18.657A8 8 0 016.343 7.343S7 9 9 10c0-2 .5-5 2.986-7C14 5 16.09 5.777 17.656 7.343A7.975 7.975 0 0120 13a7.975 7.975 0 01-2.343 5.657z" />
  <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 16.121A3 3 0 1012.015 11L11 14H9c0 .768.293 1.536.879 2.121z" />
</svg>`
  }
];
---

<ToolLayout
  title="Calculator Tools by Category | CalCluster"
  description="Browse free online calculator tools by category — math, health, science, fun, and everyday utility. Fast and accurate, no signup needed."
  canonicalUrl="https://calcluster.com/tools/"
>
  <div class="mb-12">
    <h1 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">Calculator Tools by Category</h1>
    <p class="text-slate-600 leading-relaxed text-lg max-w-3xl">
      Browse our complete collection of free online calculator tools below. Everything is fast, accurate, and requires no signup.
    </p>
  </div>

  <div class="space-y-12 mb-16">
    <!-- Math Category -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-6 border-b border-slate-200 pb-2">Math</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {mathTools.map(tool => (
          <a href={tool.link} class="block bg-white border border-slate-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:border-[#1D9E75] transition-all group">
            {tool.icon && <div class="mb-3" set:html={tool.icon} />}
            <h3 class="text-xl font-bold text-slate-900 group-hover:text-[#1D9E75] transition-colors mb-2">{tool.name}</h3>
            <p class="text-slate-600 text-sm">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Academics Category -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-6 border-b border-slate-200 pb-2">Academics</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {academicsTools.map(tool => (
          <a href={tool.link} class="block bg-white border border-slate-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:border-[#1D9E75] transition-all group">
            {tool.icon && <div class="mb-3" set:html={tool.icon} />}
            <h3 class="text-xl font-bold text-slate-900 group-hover:text-[#1D9E75] transition-colors mb-2">{tool.name}</h3>
            <p class="text-slate-600 text-sm">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Health & Fitness Category -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-6 border-b border-slate-200 pb-2">Health & Fitness</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {healthFitnessTools.map(tool => (
          <a href={tool.link} class="block bg-white border border-slate-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:border-[#1D9E75] transition-all group">
            {tool.icon && <div class="mb-3" set:html={tool.icon} />}
            <h3 class="text-xl font-bold text-slate-900 group-hover:text-[#1D9E75] transition-colors mb-2">{tool.name}</h3>
            <p class="text-slate-600 text-sm">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Science & Engineering Category -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-6 border-b border-slate-200 pb-2">Science & Engineering</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {scienceTools.map(tool => (
          <a href={tool.link} class="block bg-white border border-slate-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:border-[#1D9E75] transition-all group">
            {tool.icon && <div class="mb-3" set:html={tool.icon} />}
            <h3 class="text-xl font-bold text-slate-900 group-hover:text-[#1D9E75] transition-colors mb-2">{tool.name}</h3>
            <p class="text-slate-600 text-sm">{tool.description}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Fun & Entertainment Category -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-6 border-b border-slate-200 pb-2">Fun & Entertainment</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="block bg-slate-50 border border-slate-200 rounded-xl p-6 opacity-60 cursor-default">
          <h3 class="text-xl font-bold text-slate-500 mb-2">More tools coming soon</h3>
          <p class="text-slate-400 text-sm">We are actively building more calculators for this category.</p>
        </div>
      </div>
    </section>

    <!-- Everyday Utility Category -->
    <section>
      <h2 class="text-2xl font-bold text-slate-900 mb-6 border-b border-slate-200 pb-2">Everyday Utility</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="block bg-slate-50 border border-slate-200 rounded-xl p-6 opacity-60 cursor-default">
          <h3 class="text-xl font-bold text-slate-500 mb-2">More tools coming soon</h3>
          <p class="text-slate-400 text-sm">We are actively building more calculators for this category.</p>
        </div>
      </div>
    </section>
  </div>
</ToolLayout>