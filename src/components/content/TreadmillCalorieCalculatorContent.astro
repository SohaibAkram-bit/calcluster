          <td class="px-4 py-3">0%</td>
          <td class="px-4 py-3">3.5</td>
          <td class="px-4 py-3">~124 kcal</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3">Brisk walking</td>
          <td class="px-4 py-3">6.4 km/h</td>
          <td class="px-4 py-3">0%</td>
          <td class="px-4 py-3">5.0</td>
          <td class="px-4 py-3">~178 kcal</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3">Walking (incline)</td>
          <td class="px-4 py-3">4.8 km/h</td>
          <td class="px-4 py-3">10%</td>
          <td class="px-4 py-3">6.0</td>
          <td class="px-4 py-3">~213 kcal</td>
        </tr>
        <tr class="bg-slate-50">
          <td class="px-4 py-3">Walking (incline)</td>
          <td class="px-4 py-3">4.8 km/h</td>
          <td class="px-4 py-3">15%</td>
          <td class="px-4 py-3">7.4</td>
          <td class="px-4 py-3">~263 kcal</td>
        </tr>
        <tr class="bg-white">
          <td class="px-4 py-3">Jogging</td>
          <td class="px-4 py-3">8.0 km/h</td>
