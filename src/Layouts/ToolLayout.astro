---
import '../styles/global.css';
const { title, description, canonicalUrl, relatedTools = [] } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}

    {import.meta.env.PROD && (
      <>
        <!-- Global site tag (gtag.js) - Google Analytics -->
        <script is:inline src="https://googletagmanager.com"></script><script is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());

          gtag('config', 'G-6V7ZEWGJGB');
        </script>
      </>
    )}
  </head>
  <body class="min-h-screen flex flex-col bg-slate-50 text-slate-900 font-sans">
    <header class="bg-white border-b border-slate-200 shadow-sm relative z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <div class="flex-shrink-0">
            <a href="/" class="text-2xl font-bold text-[#1D9E75] tracking-tight">CalCluster</a>
          </div>
          <nav class="hidden sm:flex space-x-6">
            <a href="/" class="text-slate-600 hover:text-[#1D9E75] transition-colors font-medium">Home</a>
            <a href="/tools/" class="text-slate-600 hover:text-[#1D9E75] transition-colors font-medium">Categories</a>
            <a href="/about" class="text-slate-600 hover:text-[#1D9E75] transition-colors font-medium">About</a>
            <a href="/contact" class="text-slate-600 hover:text-[#1D9E75] transition-colors font-medium">Contact</a>
          </nav>
          
          <!-- Mobile Menu Button -->
          <div class="sm:hidden flex items-center">
            <button id="mobile-menu-btn" type="button" class="text-slate-600 hover:text-[#1D9E75] focus:outline-none focus:text-[#1D9E75]" aria-label="Toggle menu">
              <svg class="h-6 w-6" stroke="currentColor" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Mobile Menu Dropdown -->
      <div id="mobile-menu" class="hidden sm:hidden bg-white border-t border-slate-200 shadow-lg absolute w-full left-0 top-16">
        <nav class="px-2 pt-2 pb-4 space-y-1">
          <a href="/" class="mobile-link block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:text-[#1D9E75] hover:bg-slate-50">Home</a>
          <a href="/tools/" class="mobile-link block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:text-[#1D9E75] hover:bg-slate-50">Categories</a>
          <a href="/about" class="mobile-link block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:text-[#1D9E75] hover:bg-slate-50">About</a>
          <a href="/contact" class="mobile-link block px-3 py-2 rounded-md text-base font-medium text-slate-700 hover:text-[#1D9E75] hover:bg-slate-50">Contact</a>
        </nav>
      </div>
    </header>

    <main class="flex-grow max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
      <slot />
      {relatedTools.length > 0 && (
        <section class="mt-12 pt-8 border-t border-slate-200">
          <h2 class="text-xl font-bold text-slate-900 mb-4">Related Tools</h2>
          <div class="flex flex-wrap gap-3">
            {relatedTools.map((tool) => (
              <a href={tool.link} class="inline-block bg-white border border-slate-200 rounded-lg px-4 py-2 text-sm font-medium text-slate-700 hover:border-[#1D9E75] hover:text-[#1D9E75] transition-colors shadow-sm">
                {tool.name}
              </a>
            ))}
          </div>
        </section>
      )}
    </main>

    <footer class="bg-white border-t border-slate-200 mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-center md:text-left text-sm text-slate-500">
          &copy; 2026 CalCluster. All rights reserved.
        </p>
        <div class="flex space-x-6 text-sm text-slate-500">
          <a href="/about" class="hover:text-[#1D9E75] transition-colors">About</a>
          <a href="/contact" class="hover:text-[#1D9E75] transition-colors">Contact</a>
          <a href="/privacy-policy" class="hover:text-[#1D9E75] transition-colors">Privacy Policy</a>
          <a href="/terms-of-service" class="hover:text-[#1D9E75] transition-colors">Terms of Service</a>
        </div>
      </div>
    </footer>

    <script>
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const mobileLinks = document.querySelectorAll('.mobile-link');

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });

        // Close menu when a link is clicked
        mobileLinks.forEach(link => {
          link.addEventListener('click', () => {
            mobileMenu.classList.add('hidden');
          });
        });
      }
    </script>
  </body>
</html>
